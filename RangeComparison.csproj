<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>RangeComparison</PackageId>
    <Version>1.0.0</Version>
    <Company>Nolo COBRALINK</Company>
    <Description>Simple C# library with an extension class for range types to do range comparisons inclusive, exclusive and everything in between.</Description>
    <PackageLicenseExpression>GPL-3.0-only</PackageLicenseExpression>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <RepositoryUrl>https://github.com/nolocobralink/RangeComparison.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

</Project>
